import json
import os
from datetime import datetime
from typing import Any


class MemoryManager:
    def __init__(self, memory_file="memory/long_term_memory.json"):
        self.memory_file = memory_file
        os.makedirs(os.path.dirname(memory_file), exist_ok=True)

        if not os.path.exists(memory_file):
            with open(memory_file, "w", encoding="utf-8") as f:
                json.dump([], f, ensure_ascii=False, indent=2)

    def _load_data(self) -> list[dict]:
        if not os.path.exists(self.memory_file):
            return []

        with open(self.memory_file, "r", encoding="utf-8") as f:
            try:
                data = json.load(f)
                return data if isinstance(data, list) else []
            except json.JSONDecodeError:
                return []

    def _save_data(self, data: list[dict]) -> None:
        with open(self.memory_file, "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=2)

    def _normalize_text(self, text: str) -> str:
        return str(text or "").strip().lower()

    def _tokenize(self, text: str) -> list[str]:
        normalized = self._normalize_text(text)
        return [word for word in normalized.replace("_", " ").split() if word]

    def _task_to_memory_item(self, goal: str, task) -> dict[str, Any]:
        result_text = getattr(task, "result", None)
        if result_text is None:
            result_text = ""

        summary = str(result_text)[:300]

        return {
            "goal": goal,
            "task_id": getattr(task, "id", None),
            "task_type": getattr(task, "type", None),
            "agent": getattr(task, "agent", None),
            "task_text": getattr(task, "task", ""),
            "result": result_text,
            "summary": summary,
            "status": getattr(task, "status", None),
            "model": getattr(task, "model", None),
            "token_usage": getattr(task, "token_usage", 0),
            "depends_on": getattr(task, "depends_on", []),
            "timestamp": datetime.now().isoformat(),
        }

    def store_task_result(self, goal, task):
        data = self._load_data()
        item = self._task_to_memory_item(goal, task)
        data.append(item)
        self._save_data(data)

    def get_recent_tasks(self, limit: int = 10) -> list[dict]:
        data = self._load_data()
        return data[-limit:]

    def get_successful_tasks_by_goal(self, goal: str, limit: int = 20) -> list[dict]:
        goal_norm = self._normalize_text(goal)
        data = self._load_data()

        matched = []
        for item in data:
            if self._normalize_text(item.get("goal", "")) == goal_norm and item.get("status") == "completed":
                matched.append(item)

        return matched[-limit:]

    def _score_goal_similarity(self, current_goal: str, memory_goal: str) -> int:
        current_tokens = set(self._tokenize(current_goal))
        memory_tokens = set(self._tokenize(memory_goal))

        if not current_tokens or not memory_tokens:
            return 0

        overlap = current_tokens.intersection(memory_tokens)
        score = len(overlap)

        current_goal_norm = self._normalize_text(current_goal)
        memory_goal_norm = self._normalize_text(memory_goal)

        if current_goal_norm == memory_goal_norm:
            score += 100

        elif current_goal_norm in memory_goal_norm or memory_goal_norm in current_goal_norm:
            score += 20

        return score

    def search_similar_goals(self, goal, limit: int = 5) -> list[dict]:
        data = self._load_data()

        scored = []
        for item in data:
            memory_goal = item.get("goal", "")
            score = self._score_goal_similarity(goal, memory_goal)
            if score > 0:
                enriched = dict(item)
                enriched["_similarity_score"] = score
                scored.append(enriched)

        scored.sort(
            key=lambda x: (
                x.get("_similarity_score", 0),
                x.get("timestamp", ""),
            ),
            reverse=True,
        )

        return scored[:limit]

    def build_goal_memory_summary(self, goal: str, limit: int = 5) -> str:
        matched = self.search_similar_goals(goal, limit=limit)

        if not matched:
            return "No similar historical goals found."

        lines = []
        lines.append("Relevant historical task memory:")
        lines.append("")

        for idx, item in enumerate(matched, start=1):
            lines.append(f"{idx}. Goal: {item.get('goal', '')}")
            lines.append(f"   Task Type: {item.get('task_type', '')}")
            lines.append(f"   Agent: {item.get('agent', '')}")
            lines.append(f"   Status: {item.get('status', '')}")
            lines.append(f"   Model: {item.get('model', '')}")
            lines.append(f"   Token Usage: {item.get('token_usage', 0)}")
            lines.append(f"   Summary: {item.get('summary', '')}")
            lines.append("")

        return "\n".join(lines).strip()

    def get_common_task_types(self, goal: str, limit: int = 20) -> list[str]:
        matched = self.search_similar_goals(goal, limit=limit)

        counts = {}
        for item in matched:
            task_type = item.get("task_type")
            if not task_type:
                continue
            counts[task_type] = counts.get(task_type, 0) + 1

        ranked = sorted(counts.items(), key=lambda x: x[1], reverse=True)
        return [task_type for task_type, _ in ranked]

    def get_status(self) -> dict:
        data = self._load_data()
        return {
            "memory_file": self.memory_file,
            "total_records": len(data),
        }
